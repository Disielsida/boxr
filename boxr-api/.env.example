# БД
DATABASE_URL=postgresql://boxr:boxr@localhost:5433/boxr

# JWT — сгенерировать своими: `openssl rand -hex 64`
JWT_ACCESS_SECRET=replace_me_with_64_hex_chars
JWT_REFRESH_SECRET=replace_me_with_another_64_hex_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Хеш паролей
BCRYPT_ROUNDS=12

# HTTP
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Google Gemini AI
GEMINI_API_KEY=replace_me_with_gemini_key
AI_MODEL=gemini-2.5-flash
